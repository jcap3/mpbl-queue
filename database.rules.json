{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$sid": {
        ".read": "auth != null && $sid.matches(/^[A-HJ-NP-Z2-9]{6}$/)",
        ".write": "auth != null && $sid.matches(/^[A-HJ-NP-Z2-9]{6}$/)",
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "state": {
          ".validate": "newData.hasChildren()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}